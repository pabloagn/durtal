# =============================================================================
# Durtal — Environment Variables
# =============================================================================
# Copy to .env.local (Next.js) and .env (Python scripts)

# Database (Neon)
# Get from: Neon Dashboard → Connection String
DATABASE_URL=postgresql://neondb_owner:xxxxx@ep-xxxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# AWS S3
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=eu-central-1
S3_BUCKET=durtal

# External APIs
# Google Books: https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=xxx

# Internal Services (Docker network, production only)
CALIBRE_WEB_URL=http://calibre-web:8083

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3100
NODE_ENV=development

# Ingestion Scripts
# Path to knowledge_base.xlsx (for seed data import)
INGEST_EXCEL_PATH=/home/pabloagn/dev/phantom/src/packages/phantom-canon/data/knowledge_base.xlsx
# Path to consolidated_books.parquet (optional, TBD)
INGEST_PARQUET_PATH=
